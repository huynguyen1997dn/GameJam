  m_EditorClassIdentifier: Assembly-CSharp::JournalEntryData
  entryId: day_01_first_traces
  dayNumber: 1
  title: First Traces
  bodyText: "A fallen tree blocked the path to the square. I cut it clear before
    sundown.\n\nNobody helped \u2014 they could not understand why it mattered. By
    tomorrow they will not remember it ever lay there.\n\nBut the path stays open.
    That is how I will speak to them: not in words, in changes."
  illustration: {fileID: 0}
  clueIds:
  - clue_fresh_cut
  proofText: The road stays clear, though no one remembers the tree.
  unlockedFromStart: 0
